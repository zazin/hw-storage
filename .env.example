# MinIO (S3-compatible) connection
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=images
# Path-style addressing. The default (unset) is virtual-hosted style for Huawei
# OBS in production. MinIO (local/staging) needs path-style, so set this true.
S3_FORCE_PATH_STYLE=true

# SQLite metadata store
DB_PATH=./data/app.db
